# ===================================================================
# .gitignore
# ===================================================================

# 生成的 DXF 文件（由 DWG 转换而来）
data/cad/*.dxf

# 参数索引缓存
data/index/
data/cad/index/

# v1.0 数据库和运行时数据
data/deepastradraft.db*
data/fs/
data/uploads/
data/memory/

# 前端（Phase 5）
frontend/node_modules/
frontend/dist/

# 环境变量（包含 API Key）
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# IDE
.vscode/
.idea/

# Qoder CLI
.qoder/

# XeLaTeX 编译中间文件
*.aux
*.log
*.toc
*.out
*.lof
*.lot
*.synctex.gz
*.fls
*.fdb_latexmk

# LaTeX 生成的 PDF（源文件是 .tex）
# *.pdf

# 临时文件
*.tmp
*.bak

# macOS
.DS_Store
__MACOSX/

# LibreDWG 编译临时目录
/tmp/libredwg/
