{
  // ── 编辑器 ──
  "editor.formatOnSave": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace",
  // ── Git ──
  "gitblame.inlineMessageFormat": "${author.name} (${commit.shortHash})",
  // ── 终端 ──
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.shellIntegration.environmentReporting": true,
  // ── 工作区外观 ──
  "workbench.colorTheme": "Dark+",
  "workbench.iconTheme": "vs-seti",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  // ── Python ──
  "python.defaultInterpreterPath": "/opt/venv/bin/python",
  "python.terminal.activateEnvironment": true,
  // ── 其他 ──
  "extensions.disabledExtensions": []
}